{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "master-thesis-adf"
		},
		"ls_adls_users_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://datalakemasterthesis.dfs.core.windows.net/"
		},
		"ls_blob_users_properties_typeProperties_serviceEndpoint": {
			"type": "string",
			"defaultValue": "https://datalakemasterthesis.blob.core.windows.net/"
		},
		"ls_keyvault_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://master-thesis-key-vault.vault.azure.net/"
		},
		"ls_sql_db_dev_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "master-thesis-db-server.database.windows.net"
		},
		"ls_sql_db_dev_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "master-thesis-dev-db"
		},
		"ls_sql_db_dev_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "thesis_admin"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "master-thesis-adf_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_adls_users_properties_typeProperties_url": {
						"value": "[parameters('ls_adls_users_properties_typeProperties_url')]"
					},
					"ls_blob_users_properties_typeProperties_serviceEndpoint": {
						"value": "[parameters('ls_blob_users_properties_typeProperties_serviceEndpoint')]"
					},
					"ls_keyvault_properties_typeProperties_baseUrl": {
						"value": "[parameters('ls_keyvault_properties_typeProperties_baseUrl')]"
					},
					"ls_sql_db_dev_properties_typeProperties_server": {
						"value": "[parameters('ls_sql_db_dev_properties_typeProperties_server')]"
					},
					"ls_sql_db_dev_properties_typeProperties_database": {
						"value": "[parameters('ls_sql_db_dev_properties_typeProperties_database')]"
					},
					"ls_sql_db_dev_properties_typeProperties_userName": {
						"value": "[parameters('ls_sql_db_dev_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}